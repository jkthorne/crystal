  # Binary search for a codepoint in the sorted table.
  # Returns the replacement codepoints (StaticArray with 0-termination) or nil.
  def self.lookup(cp : UInt32) : StaticArray(UInt32, 4)?
    lo = 0
    hi = TABLE.size - 1
    while lo <= hi
      mid = lo + (hi - lo) // 2
      key = TABLE.unsafe_fetch(mid)[0]
      if key == cp
        return TABLE.unsafe_fetch(mid)[1]
      elsif key < cp
        lo = mid + 1
      else
        hi = mid - 1
      end
    end
    nil
  end
