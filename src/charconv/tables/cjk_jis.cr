# CJK Japanese tables — loaded from precomputed binary data.
# Binary files generated by tools/dump_binary_tables.cr

module CharConv::Tables::CJKJis

  # --- EUCJP: lead 0xA1-0xFE, trail 0xA1-0xFE ---
  EUCJP_LEAD_MIN = 0xA1
  EUCJP_LEAD_MAX = 0xFE
  EUCJP_TRAIL_MIN = 0xA1
  EUCJP_TRAIL_MAX = 0xFE
  EUCJP_TRAIL_COUNT = 94

  private RAW_EUCJP_DECODE = {{ read_file("#{__DIR__}/data/eucjp_decode.bin") }}
  EUCJP_DECODE = Slice.new(RAW_EUCJP_DECODE.to_unsafe.as(Pointer(UInt16)), 8836)

  private RAW_EUCJP_ENCODE_SUMMARY = {{ read_file("#{__DIR__}/data/eucjp_encode_summary.bin") }}
  EUCJP_ENCODE_SUMMARY = Slice.new(RAW_EUCJP_ENCODE_SUMMARY.to_unsafe.as(Pointer(UInt16)), 256)

  private RAW_EUCJP_ENCODE_PAGES = {{ read_file("#{__DIR__}/data/eucjp_encode_pages.bin") }}
  EUCJP_ENCODE_PAGES = begin
    ptr = RAW_EUCJP_ENCODE_PAGES.to_unsafe.as(Pointer(UInt16))
    Array(Slice(UInt16)).new(93) { |i| Slice.new(ptr + i * 256, 256) }
  end

