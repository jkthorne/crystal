  # SHIFTJIS single-byte decode/encode
  private RAW_SHIFTJIS_SINGLE_DECODE = {{ read_file("#{__DIR__}/data/shiftjis_single_decode.bin") }}
  SHIFTJIS_SINGLE_DECODE = Slice.new(RAW_SHIFTJIS_SINGLE_DECODE.to_unsafe.as(Pointer(UInt16)), 256)

  private RAW_SHIFTJIS_SINGLE_ENCODE_PAIRS = {{ read_file("#{__DIR__}/data/shiftjis_single_encode_pairs.bin") }}
  SHIFTJIS_SINGLE_ENCODE_PAIRS = begin
    data = RAW_SHIFTJIS_SINGLE_ENCODE_PAIRS.to_slice
    count = data.size // 3
    Array({UInt16, UInt8}).new(count) do |i|
      off = i * 3
      cp = (data[off].to_u16 | (data[off + 1].to_u16 << 8))
      byte = data[off + 2]
      {cp, byte}
    end
  end

